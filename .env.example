# Public storefront identity
SITE_NAME=Maison Valbridge
SITE_URL=https://www.example.com
COMPANY_NAME=Valbridge Group
CONTACT_EMAIL=info@example.com
WHOLESALE_EMAIL=wholesale@example.com

# Shopify Storefront API
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=replace-with-storefront-token
SHOPIFY_STOREFRONT_API_VERSION=2026-04

# Shopify webhook signing secret
SHOPIFY_WEBHOOK_SECRET=replace-with-webhook-secret
